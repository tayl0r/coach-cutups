import { LineEdit } from "std-widgets.slint";

export component MainWindow inherits Window {
    title: "Video Coach";
    preferred-width: 1280px;
    preferred-height: 800px;

    in property <string> project-title: "No project open";
    in property <string> error-message: "";
    // Phase 7 Task 4: video surface. Updated by the UI thread at 30Hz
    // from the latest decoded frame written by SourcePlayer's Slint
    // FrameSink. Source-fit "contain" keeps aspect ratio.
    in property <image> source-frame;

    // Phase 7 Task 5: transport state, written by the position-poll
    // task at ~10 Hz, displayed by the UI at 30 Hz.
    in property <bool> is-playing: false;
    in property <float> position-seconds: 0;
    in property <float> duration-seconds: 0;
    // Phase 7 Task 7. UI-side defaults to 1.0; we don't hydrate from
    // project.preferences in Phase 7 MVP, so the slider starts maxed
    // each session. Phase 8+ can add a project-loaded → set this hook.
    in-out property <float> scan-volume: 1.0;

    // Phase 8 Task 3. Recording mode + elapsed timer, written by the
    // 30 Hz timer in ui.rs reading RecordingStateSlot. Mode is one of
    // "scanning", "recording_starting", "recording" (matching
    // bus::AppMode's snake_case serde). The REC indicator + M:SS
    // label below switch on this string.
    //
    // Phase 9 Task 4. Mode also gains "preview_clip" — when set the
    // sidebar selection highlights the active clip and the transport
    // bar shows a "← Source" button + the clip name.
    in property <string> mode: "scanning";
    in property <float> recording-elapsed-seconds: 0;

    // Phase 9 Task 4. Sidebar of clips for the currently-open project.
    // Hydrated by ui.rs's 30 Hz timer reading the bus's `ClipListSlot`.
    // Each row carries a stringified clip-id (the `clip-clicked`
    // callback re-emits it; the Rust handler parses + dispatches
    // OpenClipPreview { clip_id }).
    in property <[{id: string, name: string, duration: float}]> clips: [];
    // Clip currently in preview, as the same stringified UUID. Used to
    // highlight the active row in the sidebar. Empty string when
    // mode != "preview_clip".
    in property <string> selected-clip-id: "";
    // Display name of the previewing clip — shown center of the
    // transport bar when mode == "preview_clip".
    in property <string> preview-clip-name: "";

    callback new-project-clicked();
    callback open-project-clicked();
    callback add-source-video-clicked();
    callback quit-clicked();
    callback play-pause-clicked();
    // accurate=false during drag; accurate=true on release. UI dispatches
    // both via two separate callbacks so the bus can route to different
    // GST_SEEK_FLAG values.
    callback scrub-dragged(float);
    callback scrub-released(float);
    // Phase 7 Task 6: skip buttons + keyboard shortcuts. delta-seconds
    // can be positive or negative; the UI handler resolves the new
    // position by adding delta to the current position-seconds.
    callback skip-clicked(int);
    callback scan-volume-changed(float);
    // Phase 8 Task 3. R-press toggles between StartClipRecording and
    // StopClipRecording; the Rust handler reads `mode` and dispatches
    // accordingly. While `recording_starting` the press is ignored
    // (mid-transition).
    callback record-toggled();
    // Phase 8 Task 4. Fired once per stroke (mouse-down → drag →
    // mouse-up) inside the source-frame area when mode == "recording".
    // `points-json` is a JSON-encoded array of objects
    // `{"x": float, "y": float, "t": float}` where x/y are normalized
    // [0,1] against the displayed (post-letterbox) video rect and t is
    // seconds since stroke-start. The Rust handler wraps this in a
    // CommentaryEvent { kind: Stroke } via Command::AppendStroke.
    callback stroke-completed(string);

    // Phase 9 Task 4. A clip in the sidebar was clicked. The Rust
    // handler dispatches `OpenClipPreview { clip_id }` with the same
    // stringified UUID.
    callback clip-clicked(string);
    // Phase 9 Task 4. The "← Source" button in the transport bar (or
    // Esc key) was activated while in preview mode. The Rust handler
    // dispatches `ClosePreview`.
    callback close-preview-clicked();

    // Phase 10 Task 3. Export-sheet UI state.
    //
    // tag-rows: hydrated by ui.rs's 30 Hz timer from ClipListSlot via
    // tag-aggregation. The first row is always the synthetic "All
    // Clips" row carrying the literal tag value `__all__`; real tag
    // rows follow, sorted alphabetically. `clip-count`, `duration`,
    // and `selected` are read-only display fields.
    //
    // Slint's pure-function language doesn't support `for` loops over
    // lists, so we can't write an `is-selected(tag)` helper that
    // queries `selected-export-tags`. The Rust side (which holds the
    // canonical selection state) re-emits the rows whenever the
    // selection changes, with `selected` set per row.
    in property <[{tag: string, label: string, clip-count: int, duration: float, selected: bool}]> export-tag-rows: [];

    // Selected tags (the literal tag values from `export-tag-rows`,
    // i.e. `__all__` for the synthetic row + real tag names). The
    // form-view checkboxes mutate this through the
    // `export-tag-toggled` callback. `selected-export-tags` doubles
    // as the dispatch payload — the Rust handler maps each entry to a
    // `TagSelection` enum variant.
    in-out property <[string]> selected-export-tags: [];

    // Form fields. Resolution/quality are string discriminants the
    // Rust side maps to enum variants; project name is an editable
    // string the UI seeds from the open project's name.
    in-out property <string> export-output-folder: "";
    in-out property <string> export-resolution: "1080";
    in-out property <string> export-quality: "medium";
    // Phase 11 Plan #3 Task 2: HEVC vs H.264 picker. "h264" / "hevc"
    // discriminants the Rust side maps to `Codec::H264` / `Codec::Hevc`.
    // Default mirrors Project::Preferences (H.264).
    in-out property <string> export-codec: "h264";
    // Phase 11 Plan #7 Task 1: free-form filename template. Supported
    // placeholders: `{tag}`, `{project}`, `{date}`. Default value matches
    // Phase 10's hard-coded format byte-for-byte. Sheet-open hydration in
    // ui.rs writes the persisted prefs value over this default before the
    // sheet appears (Task 2 wires the prefs read; Task 1 ships placeholder
    // hydration to the default).
    in-out property <string> export-filename-template: "{tag} - {project}";
    in-out property <string> export-project-name: "";

    // Phase 11 Plan #7 Task 1 (fix #9). Top Repeater renders selected tags
    // in user-chosen order with drag handles; bottom Repeater renders
    // unselected tags alphabetically. `export-tag-rows` is retained as the
    // hidden source-of-truth model used during hydration to compute the
    // split — it isn't visible. Task 2 partitions the model properly; Task
    // 1 ships placeholder splits (selected = empty, unselected = all).
    in-out property <[{tag: string, label: string, clip-count: int, duration: float}]> selected-export-tag-rows: [];
    in-out property <[{tag: string, label: string, clip-count: int, duration: float}]> unselected-export-tag-rows: [];

    // Phase 11 Plan #7 Task 1 (fixes #3, #4, #5). Drag-reorder gesture
    // state for the selected-tag list. `dragging-tag-index == -1` means
    // no drag in flight (also gates the Export button per fix #5);
    // `drag-start-y` / `drag-current-y` are absolute window coordinates;
    // `selected-list-top-y` is the absolute Y of the top Repeater's
    // parent rectangle (used by the Rust handler to compute the drop's
    // relative Y per fix #4).
    in-out property <int> dragging-tag-index: -1;
    in-out property <length> drag-start-y: 0px;
    in-out property <length> drag-current-y: 0px;
    in-out property <length> selected-list-top-y: 0px;

    // Mirrored from `ExportProgressSlot` in ui.rs's 30 Hz timer. The
    // outcome-kind string is the canonical view selector — one of
    // "none" (form view) | "in_progress" (progress view) |
    // "succeeded_all" (success summary) | "partial_failure" (error
    // summary) | "cancelled" (cancellation summary). The remaining
    // `export-*` properties carry per-state details: `total-tags` /
    // `completed-tags` / `current-tag` for in_progress;
    // `summary-folder` + `summary-file-count` for succeeded_all;
    // `error` + `failed-tag` for partial_failure;
    // `cancelled-completed` for cancelled.
    in property <string> export-outcome-kind: "none";
    in property <bool> export-active: false;
    in property <int> export-total-tags: 0;
    in property <int> export-completed-tags: 0;
    in property <string> export-current-tag: "";
    in property <string> export-error: "";
    in property <string> export-summary-folder: "";
    in property <int> export-summary-file-count: 0;
    in property <string> export-failed-tag: "";
    in property <int> export-cancelled-completed: 0;
    // Phase 11 Plan #2: real progress %.
    in property <float> export-current-tag-progress: 0.0;
    in property <float> export-batch-progress: 0.0;

    // True when a project is open. Gates the File→Export
    // Compilations menu item's `activated` body so a stray click on
    // a disabled-but-visible menu item is a no-op rather than a
    // sheet that shows an empty form.
    in property <bool> project-open: false;

    // Sheet visibility. Set true by the File menu (subject to
    // project-open) and by a Slint changed-callback hook in ui.rs
    // that calls .focus() on `sheet-focus-scope`. Set false by
    // `export-close-clicked` (Esc, click-outside, Done/Cancel
    // buttons, all wired through ui.rs::on_export_close_clicked).
    in-out property <bool> export-sheet-visible: false;

    callback export-folder-pick-clicked();
    // String payload is the literal tag value from
    // `export-tag-rows` (the synthetic AllClips row uses
    // `__all__`).
    callback export-tag-toggled(string);
    callback export-select-all-clicked();
    callback export-select-none-clicked();
    callback export-resolution-changed(string);
    callback export-quality-changed(string);
    // Phase 11 Plan #3 Task 2: Codec radio change ("h264" / "hevc").
    callback export-codec-changed(string);
    // Phase 11 Plan #7 Task 1: filename-template LineEdit edit. Fires on
    // every keystroke (Slint's LineEdit `edited` signal). Rust handler
    // mirrors the codec one — straight property write-through.
    callback export-filename-template-changed(string);
    // Phase 11 Plan #7 Task 1 (fix #9). Drag-released callback for the
    // top (selected) Repeater. `from-index` is the row index in the
    // top model; `relative-drop-y` is the cursor Y at release minus
    // `selected-list-top-y` so the Rust side can divide by row height
    // to find the destination index without caring about the list's
    // absolute window position.
    callback export-tag-drag-released(int, length);
    // Phase 11 Plan #3 Task 2 (fix #8): mandatory sheet-open hydration.
    // Replaces an inline `export-sheet-visible = true` assignment in the
    // File menu so the Rust side can hydrate the three pickers from
    // persisted prefs BEFORE the sheet appears.
    callback export-sheet-open-clicked();
    callback export-start-clicked();
    callback export-cancel-clicked();
    callback export-close-clicked();
    callback export-reveal-clicked();

    // Capture keyboard focus at root so Space / arrow keys hit the
    // transport handlers regardless of which TouchArea last clicked.
    forward-focus: keyscope;

    MenuBar {
        Menu {
            title: "File";
            MenuItem {
                title: "New Project…";
                activated => { root.new-project-clicked(); }
            }
            MenuItem {
                title: "Open Project…";
                activated => { root.open-project-clicked(); }
            }
            MenuItem {
                title: "Add Source Video…";
                activated => { root.add-source-video-clicked(); }
            }
            // Phase 10 Task 3. Disabled (no-op) when no project is
            // open — Slint MenuItem doesn't expose an `enabled`
            // property in this version, so we gate the activated
            // body. `export-project-name` is seeded by ui.rs's
            // 30 Hz timer from the open project's name; the sheet's
            // form view shows it (read-only) so the user can verify
            // the file naming before clicking Export.
            MenuItem {
                title: "Export Compilations…";
                activated => {
                    // Phase 11 Plan #3 Task 2 (fix #8): defer the
                    // visibility flip to the Rust binding for
                    // `export-sheet-open-clicked`, which hydrates
                    // resolution / quality / codec from prefs before
                    // showing the sheet. The project-open gate stays
                    // here so disabled-but-visible MenuItem clicks
                    // remain a no-op.
                    if (root.project-open) {
                        root.export-sheet-open-clicked();
                    }
                }
            }
            MenuItem {
                title: "Quit";
                activated => { root.quit-clicked(); }
            }
        }
    }

    keyscope := FocusScope {
        width: 100%;
        height: 100%;
        key-pressed(event) => {
            // Phase 10 Task 3 (per fix #32). When the export sheet is
            // visible, ALL existing key bindings (Space, R, arrow
            // keys, Esc-for-preview-close) are suppressed at the
            // top-level keyscope. The sheet's own focus scope handles
            // Esc; everything else just no-ops while the modal is up
            // so a stray R doesn't start a recording behind the
            // sheet, etc.
            if (root.export-sheet-visible) {
                return reject;
            }
            if (event.text == " ") {
                root.play-pause-clicked();
                return accept;
            }
            if (event.text == Key.LeftArrow) {
                root.skip-clicked(event.modifiers.shift ? -10 : -3);
                return accept;
            }
            if (event.text == Key.RightArrow) {
                root.skip-clicked(event.modifiers.shift ? 10 : 3);
                return accept;
            }
            if (event.text == "r") {
                root.record-toggled();
                return accept;
            }
            // Phase 9 Task 4. Esc closes the active preview; pass-through
            // for every other mode (so future Esc handlers in dialogs
            // etc. can pick it up unchanged).
            if (event.text == Key.Escape) {
                if (root.mode == "preview_clip") {
                    root.close-preview-clicked();
                    return accept;
                }
                return reject;
            }
            return reject;
        }
    }

    // Phase 9 Task 4. Source video surface — fills the area to the
    // right of the clip sidebar (200px wide when clips.length > 0,
    // collapsed to 0 when the project has no clips so the surface
    // fills the full window the same as Phase 7/8).
    source-frame-image := Image {
        x: clips.length > 0 ? 200px : 0;
        y: 0;
        width: parent.width - (clips.length > 0 ? 200px : 0px);
        height: parent.height - 56px;
        image-fit: contain;
        source: source-frame;
    }

    // Phase 8 Task 4. Stroke capture overlay. Positioned identically to
    // source-frame-image; enabled only while mode == "recording" so
    // resting clicks during scanning don't accidentally accumulate
    // points. Letterbox normalization is folded into pointer-event /
    // moved handlers (adversarial fix #5): the rendered video rect
    // (post `image-fit: contain`) is computed from the source image's
    // pixel dimensions vs. the container, then the touch (cw, ch)
    // touch coordinates are converted to [0,1] against that rect (NOT
    // against the whole container) and clamped AFTER the conversion so
    // strokes drawn on the letterbox boundary still land in the buffer.
    //
    // Per-point t is `animation-tick() - stroke-press-tick` in seconds
    // (Slint's animation-tick returns a duration since process start;
    // arithmetic on durations yields a duration, and dividing by `1s`
    // yields seconds as float). The buffer is built incrementally as a
    // JSON string (adversarial fix #6 — single callback per stroke,
    // no Slint ModelRc plumbing); on release the closing `]` is
    // appended and stroke-completed fires.
    Rectangle {
        x: source-frame-image.x;
        y: source-frame-image.y;
        width: source-frame-image.width;
        height: source-frame-image.height;
        background: transparent;

        property <duration> stroke-press-tick: 0;
        property <int> stroke-point-count: 0;
        property <string> stroke-buf: "";

        // Computed once per query; pure functions of the container size
        // and source image's reported pixel dimensions. If the source
        // image isn't yet decoded (size 0×0), the rect collapses to
        // the container — strokes during that race window are
        // dispatched normalized against the container, which is at
        // worst a slight visual mismatch with no data integrity loss.
        function video-aspect() -> float {
            return source-frame.height > 0 ? (source-frame.width / source-frame.height) : 1;
        }
        function rendered-w() -> float {
            return self.width / 1px >= self.height / 1px * video-aspect()
                ? self.height / 1px * video-aspect()
                : self.width / 1px;
        }
        function rendered-h() -> float {
            return self.width / 1px >= self.height / 1px * video-aspect()
                ? self.height / 1px
                : self.width / 1px / video-aspect();
        }
        function offset-x() -> float {
            return (self.width / 1px - rendered-w()) / 2;
        }
        function offset-y() -> float {
            return (self.height / 1px - rendered-h()) / 2;
        }
        function clamp01(v: float) -> float {
            return max(0, min(1, v));
        }

        stroke-area := TouchArea {
            width: parent.width;
            height: parent.height;
            // enabled stays false outside Recording so the underlying
            // Image / window keyboard focus chain isn't blocked by a
            // hot TouchArea during scanning.
            enabled: root.mode == "recording";
            pointer-event(event) => {
                if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                    parent.stroke-press-tick = animation-tick();
                    parent.stroke-point-count = 0;
                    parent.stroke-buf = "[";
                }
                if (event.kind == PointerEventKind.up && event.button == PointerEventButton.left) {
                    if (parent.stroke-point-count > 0) {
                        parent.stroke-buf = parent.stroke-buf + "]";
                        root.stroke-completed(parent.stroke-buf);
                    }
                    parent.stroke-buf = "";
                    parent.stroke-point-count = 0;
                }
            }
            moved => {
                if (self.pressed) {
                    // Letterbox-normalize. mouse-x / mouse-y are local
                    // floats in px (Slint divides duration by px).
                    parent.stroke-buf = parent.stroke-buf
                        + (parent.stroke-point-count > 0 ? "," : "")
                        + "{\"x\":"
                        + parent.clamp01((self.mouse-x / 1px - parent.offset-x()) / parent.rendered-w())
                        + ",\"y\":"
                        + parent.clamp01((self.mouse-y / 1px - parent.offset-y()) / parent.rendered-h())
                        + ",\"t\":"
                        + ((animation-tick() - parent.stroke-press-tick) / 1s)
                        + "}";
                    parent.stroke-point-count = parent.stroke-point-count + 1;
                }
            }
        }
    }

    // Phase 9 Task 4. Clip sidebar. Fixed 200 px on the left edge,
    // visible only when the current project has at least one clip.
    // Each row shows the clip's name + duration formatted as M:SS;
    // clicking dispatches `clip-clicked(clip-id)` which the Rust
    // handler maps to OpenClipPreview. The active clip is
    // highlighted via `selected-clip-id`.
    if clips.length > 0: Rectangle {
        x: 0;
        y: 0;
        width: 200px;
        height: parent.height - 56px;
        background: #181818;
        VerticalLayout {
            x: 0; y: 0;
            width: parent.width;
            spacing: 0;
            padding: 0;
            for clip[idx] in clips: Rectangle {
                height: 44px;
                background: clip.id == root.selected-clip-id
                    ? #2c5d8a
                    : (clip-area.has-hover ? #242424 : transparent);
                Text {
                    x: 8px;
                    y: 4px;
                    width: parent.width - 16px;
                    height: 18px;
                    text: clip.name;
                    font-size: 13px;
                    color: #ffffff;
                    overflow: elide;
                }
                Text {
                    x: 8px;
                    y: 22px;
                    width: parent.width - 16px;
                    height: 16px;
                    text: format-mmss(clip.duration);
                    font-size: 11px;
                    color: #aaaaaa;
                }
                clip-area := TouchArea {
                    width: parent.width;
                    height: parent.height;
                    clicked => { root.clip-clicked(clip.id); }
                }
            }
        }
    }

    Text {
        x: clips.length > 0 ? 216px : 16px;
        y: 16px;
        text: project-title;
        font-size: 18px;
        color: #ffffff;
    }

    // Phase 8 Task 3. REC indicator — top-left corner just below the
    // project title. Visible only when mode != "scanning". Yellow +
    // "Preparing…" while pipeline is constructing (RecordingStarting),
    // red + "REC M:SS" once the capture pipeline is rolling.
    if mode != "scanning": Rectangle {
        x: 16px;
        y: 44px;
        width: 160px;
        height: 28px;
        background: transparent;
        // Dot
        Rectangle {
            x: 0;
            y: (parent.height - self.height) / 2;
            width: 12px;
            height: 12px;
            border-radius: 6px;
            background: mode == "recording" ? #e63946 : #f4c430;
        }
        // Label
        Text {
            x: 18px;
            y: 0;
            width: parent.width - 18px;
            height: parent.height;
            vertical-alignment: center;
            font-size: 14px;
            color: mode == "recording" ? #e63946 : #f4c430;
            text: mode == "recording"
                ? "REC " + format-mmss(root.recording-elapsed-seconds)
                : "Preparing…";
        }
    }

    if error-message != "": Text {
        x: 16px;
        y: 48px;
        text: error-message;
        font-size: 14px;
        color: #ff6464;
        wrap: word-wrap;
        width: parent.width - 32px;
    }

    // Transport bar at the bottom: play/pause + custom scrub track +
    // position label.
    //
    // Phase 9 Task 4. In preview_clip mode the bar gains a "← Source"
    // button at its left edge and a center label with the clip name.
    // The skip / play / scrub / volume controls remain in place;
    // play/pause/scrub already route to the active pipeline (preview
    // when in preview mode) per the bus's Task 3 dispatch.
    Rectangle {
        x: 0;
        y: parent.height - 56px;
        width: parent.width;
        height: 56px;
        background: #1a1a1a;

        // Phase 9 Task 4. Close-preview button. Hidden outside
        // preview_clip mode; visible at the very left edge in preview
        // mode where it replaces nothing — the existing skip-back-10
        // button shifts right when this is visible by means of an `if`
        // wrapping the close button rather than relative-positioning,
        // because Slint's `if`-conditional siblings keep the original
        // x-anchors intact (skip-back-10 sits at x: 12px regardless of
        // the close button's presence; the two stack at the same x but
        // are mutually exclusive).
        if mode == "preview_clip": close-preview-button := Rectangle {
            x: 12px;
            y: (parent.height - self.height) / 2;
            width: 96px;
            height: 32px;
            border-radius: 4px;
            background: close-area.pressed
                ? #303030
                : (close-area.has-hover ? #2a2a2a : transparent);
            Text {
                text: "← Source";
                font-size: 13px;
                color: #ffffff;
                horizontal-alignment: center;
                vertical-alignment: center;
                width: parent.width;
                height: parent.height;
            }
            close-area := TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => { root.close-preview-clicked(); }
            }
        }

        // Skip −10s
        skip-back-10 := Rectangle {
            x: mode == "preview_clip" ? 116px : 12px;
            y: (parent.height - self.height) / 2;
            width: 32px;
            height: 32px;
            border-radius: 4px;
            background: sb10-area.pressed ? #303030 : (sb10-area.has-hover ? #2a2a2a : transparent);
            Text {
                text: "⏪";
                font-size: 14px;
                color: #ffffff;
                horizontal-alignment: center;
                vertical-alignment: center;
                width: parent.width;
                height: parent.height;
            }
            sb10-area := TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => { root.skip-clicked(-10); }
            }
        }
        // Skip −3s
        skip-back-3 := Rectangle {
            x: skip-back-10.x + skip-back-10.width + 4px;
            y: (parent.height - self.height) / 2;
            width: 32px;
            height: 32px;
            border-radius: 4px;
            background: sb3-area.pressed ? #303030 : (sb3-area.has-hover ? #2a2a2a : transparent);
            Text {
                text: "−3";
                font-size: 12px;
                color: #ffffff;
                horizontal-alignment: center;
                vertical-alignment: center;
                width: parent.width;
                height: parent.height;
            }
            sb3-area := TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => { root.skip-clicked(-3); }
            }
        }
        play-button := Rectangle {
            x: skip-back-3.x + skip-back-3.width + 4px;
            y: (parent.height - self.height) / 2;
            width: 32px;
            height: 32px;
            border-radius: 4px;
            background: play-area.pressed ? #303030 : (play-area.has-hover ? #2a2a2a : transparent);

            Text {
                text: is-playing ? "❚❚" : "▶";
                font-size: 18px;
                color: #ffffff;
                horizontal-alignment: center;
                vertical-alignment: center;
                width: parent.width;
                height: parent.height;
            }

            play-area := TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => { root.play-pause-clicked(); }
            }
        }
        // Skip +3s
        skip-fwd-3 := Rectangle {
            x: play-button.x + play-button.width + 4px;
            y: (parent.height - self.height) / 2;
            width: 32px;
            height: 32px;
            border-radius: 4px;
            background: sf3-area.pressed ? #303030 : (sf3-area.has-hover ? #2a2a2a : transparent);
            Text {
                text: "+3";
                font-size: 12px;
                color: #ffffff;
                horizontal-alignment: center;
                vertical-alignment: center;
                width: parent.width;
                height: parent.height;
            }
            sf3-area := TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => { root.skip-clicked(3); }
            }
        }
        // Skip +10s
        skip-fwd-10 := Rectangle {
            x: skip-fwd-3.x + skip-fwd-3.width + 4px;
            y: (parent.height - self.height) / 2;
            width: 32px;
            height: 32px;
            border-radius: 4px;
            background: sf10-area.pressed ? #303030 : (sf10-area.has-hover ? #2a2a2a : transparent);
            Text {
                text: "⏩";
                font-size: 14px;
                color: #ffffff;
                horizontal-alignment: center;
                vertical-alignment: center;
                width: parent.width;
                height: parent.height;
            }
            sf10-area := TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => { root.skip-clicked(10); }
            }
        }

        // Custom scrubber: a fill bar inside a track Rectangle, with a
        // TouchArea overlay handling drag + release. Slint 1.16's
        // built-in Slider doesn't expose pressed/released as separate
        // events, which the hybrid-seek policy needs.
        track := Rectangle {
            x: skip-fwd-10.x + skip-fwd-10.width + 12px;
            y: (parent.height - 6px) / 2;
            width: time-label.x - self.x - 12px;
            height: 6px;
            border-radius: 3px;
            background: #2a2a2a;

            // Played fill
            Rectangle {
                x: 0;
                y: 0;
                height: parent.height;
                width: parent.width * (root.duration-seconds > 0
                    ? root.position-seconds / root.duration-seconds
                    : 0);
                border-radius: 3px;
                background: #4a90e2;
            }

            scrub-area := TouchArea {
                width: parent.width;
                height: parent.height;
                pointer-event(event) => {
                    if (event.kind == PointerEventKind.up && event.button == PointerEventButton.left) {
                        if (root.duration-seconds > 0) {
                            root.scrub-released(self.mouse-x / self.width * root.duration-seconds);
                        }
                    }
                }
                moved => {
                    if (self.pressed && root.duration-seconds > 0) {
                        root.scrub-dragged(self.mouse-x / self.width * root.duration-seconds);
                    }
                }
            }
        }

        // Position / duration label, mm:ss format. Slint expressions
        // don't have a built-in mm:ss formatter; we inline the math.
        time-label := Text {
            x: volume-track.x - self.width - 16px;
            y: (parent.height - self.height) / 2;
            text: format-mmss(root.position-seconds) + " / " + format-mmss(root.duration-seconds);
            font-size: 13px;
            color: #cccccc;
            font-family: "Menlo";
        }

        // Scan-volume slider (right edge). Custom-built like the
        // scrubber: track + fill + TouchArea, so drag handlers stay
        // consistent with the rest of the bar. Slint's built-in Slider
        // also works here but using TouchArea keeps the visual style
        // matched.
        volume-track := Rectangle {
            x: parent.width - self.width - 12px;
            y: (parent.height - 6px) / 2;
            width: 96px;
            height: 6px;
            border-radius: 3px;
            background: #2a2a2a;

            Rectangle {
                x: 0; y: 0;
                width: parent.width * root.scan-volume;
                height: parent.height;
                border-radius: 3px;
                background: #888;
            }

            volume-area := TouchArea {
                width: parent.width;
                height: parent.height;
                moved => {
                    if (self.pressed) {
                        root.scan-volume = max(0, min(1, self.mouse-x / self.width));
                        root.scan-volume-changed(root.scan-volume);
                    }
                }
                pointer-event(event) => {
                    if (event.kind == PointerEventKind.up && event.button == PointerEventButton.left) {
                        root.scan-volume = max(0, min(1, self.mouse-x / self.width));
                        root.scan-volume-changed(root.scan-volume);
                    }
                }
            }
        }
    }

    // Phase 9 Task 4. Preview clip-name label floating just above the
    // transport bar. Visible only in preview_clip mode so it doesn't
    // conflict with the recording flow's overlay area. The text is
    // hydrated by ui.rs's 30 Hz timer from the active clip's name.
    if mode == "preview_clip" && preview-clip-name != "": Rectangle {
        x: (parent.width - self.width) / 2;
        y: parent.height - 56px - 28px;
        width: min(400px, max(120px, preview-name-text.preferred-width + 24px));
        height: 24px;
        border-radius: 4px;
        background: #00000099;
        preview-name-text := Text {
            x: 12px;
            y: 0;
            width: parent.width - 24px;
            height: parent.height;
            text: preview-clip-name;
            font-size: 13px;
            color: #ffffff;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    // Phase 10 Task 3. Export-sheet modal overlay.
    //
    // Visibility-gated on `export-sheet-visible`. The dim layer's
    // TouchArea absorbs clicks behind the card so the underlying
    // sidebar/transport stay inert while the sheet is open. The
    // card itself is centred; its sub-views switch on
    // `export-outcome-kind`:
    //   "none"            → form view (tag list + pickers + Export)
    //   "in_progress"     → progress view (current tag + Cancel)
    //   "succeeded_all"   → success summary (Reveal + Done)
    //   "partial_failure" → error summary
    //   "cancelled"       → cancellation summary
    //
    // Esc + click-outside dismiss the sheet only when outcome is NOT
    // in_progress (per fix #32 — can't accidentally drop a running
    // export by clicking outside).
    if export-sheet-visible: Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        background: #000000aa;

        sheet-touch := TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => {
                if (root.export-outcome-kind != "in_progress") {
                    root.export-close-clicked();
                }
            }
        }

        sheet-focus-scope := FocusScope {
            width: parent.width;
            height: parent.height;
            key-pressed(event) => {
                if (event.text == Key.Escape) {
                    if (root.export-outcome-kind != "in_progress") {
                        root.export-close-clicked();
                    }
                    return accept;
                }
                return reject;
            }

            // The card. A second TouchArea inside the card absorbs
            // clicks so they DON'T propagate to the dim-layer's
            // sheet-touch (which would close the sheet on every
            // checkbox click otherwise).
            card := Rectangle {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                width: 560px;
                // Phase 11 Plan #3 Task 2: bumped from 540px to 600px to
                // fit the new Codec radio row at y:430-480px.
                // Phase 11 Plan #7 Task 1: bumped from 600px to 680px to
                // fit the new Filename label + LineEdit + hint text below
                // the Codec row (~80px). The Cancel/Export bottom buttons
                // are anchored to `parent.height - 52px` so they ride
                // down with the new height.
                height: 680px;
                border-radius: 8px;
                background: #1f1f1f;
                border-width: 1px;
                border-color: #303030;

                card-touch := TouchArea {
                    width: parent.width;
                    height: parent.height;
                    // No clicked handler — purely an absorber.
                }

                // Card title (constant across all outcome views).
                Text {
                    x: 24px;
                    y: 20px;
                    width: parent.width - 48px;
                    height: 24px;
                    text: root.export-outcome-kind == "in_progress"
                        ? "Exporting…"
                        : (root.export-outcome-kind == "succeeded_all"
                            ? "Export complete"
                            : (root.export-outcome-kind == "partial_failure"
                                ? "Export failed"
                                : (root.export-outcome-kind == "cancelled"
                                    ? "Export cancelled"
                                    : "Export Compilations")));
                    font-size: 16px;
                    color: #ffffff;
                }

                // ────────────────────────────── Form view ───────
                if root.export-outcome-kind == "none": Rectangle {
                    x: 0;
                    y: 56px;
                    width: parent.width;
                    height: parent.height - 56px;

                    // Tag list header + Select All / None.
                    Text {
                        x: 24px;
                        y: 0;
                        width: 200px;
                        height: 18px;
                        text: "Tags";
                        font-size: 13px;
                        color: #aaaaaa;
                    }
                    sa-button := Rectangle {
                        x: parent.width - 184px;
                        y: -2px;
                        width: 76px;
                        height: 22px;
                        border-radius: 4px;
                        background: sa-area.pressed
                            ? #404040
                            : (sa-area.has-hover ? #2e2e2e : #262626);
                        Text {
                            x: 0; y: 0;
                            width: parent.width; height: parent.height;
                            text: "Select all";
                            font-size: 11px;
                            color: #ffffff;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        sa-area := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => { root.export-select-all-clicked(); }
                        }
                    }
                    sn-button := Rectangle {
                        x: parent.width - 104px;
                        y: -2px;
                        width: 80px;
                        height: 22px;
                        border-radius: 4px;
                        background: sn-area.pressed
                            ? #404040
                            : (sn-area.has-hover ? #2e2e2e : #262626);
                        Text {
                            x: 0; y: 0;
                            width: parent.width; height: parent.height;
                            text: "Select none";
                            font-size: 11px;
                            color: #ffffff;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        sn-area := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => { root.export-select-none-clicked(); }
                        }
                    }

                    // Tag-list scrollable area. Phase 11 Plan #7 Task 1
                    // (fix #9): split into TWO stacked Repeaters — top
                    // renders `selected-export-tag-rows` (user-chosen
                    // order, with `☰` drag handles); bottom renders
                    // `unselected-export-tag-rows` (alphabetic, no drag
                    // handles).
                    Rectangle {
                        x: 24px;
                        y: 28px;
                        width: parent.width - 48px;
                        height: 200px;
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: #303030;
                        background: #161616;

                        Flickable {
                            x: 0; y: 0;
                            width: parent.width;
                            height: parent.height;
                            viewport-width: parent.width;
                            viewport-height: max(
                                parent.height,
                                (root.selected-export-tag-rows.length + root.unselected-export-tag-rows.length) * 32px + 4px
                            );

                            VerticalLayout {
                                x: 0; y: 2px;
                                width: parent.width;
                                spacing: 0;
                                padding: 0;

                                // Top Repeater: SELECTED tag rows in user-
                                // chosen order. Each row carries TWO
                                // TouchAreas (fix #3) — `row-toggle-area`
                                // (full-row click → toggle) declared
                                // first, `drag-handle-area` (24×24 px far
                                // left, ☰ glyph) declared SECOND so it
                                // z-orders above and consumes presses
                                // there before the row toggle sees them.
                                selected-list := Rectangle {
                                    width: parent.width;
                                    height: root.selected-export-tag-rows.length * 32px;
                                    background: transparent;

                                    // Capture absolute window-Y of this
                                    // rectangle so the Rust handler can
                                    // compute the relative drop Y on
                                    // release (fix #4).
                                    changed absolute-position => {
                                        root.selected-list-top-y = self.absolute-position.y;
                                    }

                                    for row[idx] in root.selected-export-tag-rows: Rectangle {
                                        x: 0;
                                        y: idx * 32px;
                                        width: parent.width;
                                        height: 32px;
                                        background: root.dragging-tag-index == idx
                                            ? #3a3a3a
                                            : (sel-toggle-area.pressed
                                                ? #2c5d8a
                                                : (sel-toggle-area.has-hover ? #232323 : #262626));

                                        // Checkbox indicator (always selected on top list).
                                        Rectangle {
                                            x: 32px;
                                            y: (parent.height - self.height) / 2;
                                            width: 16px;
                                            height: 16px;
                                            border-radius: 3px;
                                            border-width: 1px;
                                            border-color: #707070;
                                            background: #4a90e2;
                                            Text {
                                                x: 0; y: 0;
                                                width: parent.width;
                                                height: parent.height;
                                                text: "✓";
                                                font-size: 12px;
                                                color: #ffffff;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }

                                        // Label.
                                        Text {
                                            x: 56px;
                                            y: 0;
                                            width: parent.width - 224px;
                                            height: parent.height;
                                            text: row.label;
                                            font-size: 13px;
                                            color: #ffffff;
                                            vertical-alignment: center;
                                            overflow: elide;
                                        }

                                        // Right-aligned count + duration.
                                        Text {
                                            x: parent.width - 168px;
                                            y: 0;
                                            width: 160px;
                                            height: parent.height;
                                            text: row.clip-count + " clip" + (row.clip-count == 1 ? "" : "s") + " · " + format-mmss(row.duration);
                                            font-size: 11px;
                                            color: #aaaaaa;
                                            vertical-alignment: center;
                                            horizontal-alignment: right;
                                        }

                                        // Row-wide toggle area (declared FIRST so it sits below).
                                        sel-toggle-area := TouchArea {
                                            width: parent.width;
                                            height: parent.height;
                                            clicked => { root.export-tag-toggled(row.tag); }
                                        }

                                        // Drag handle: ☰ glyph + 24×24 hit-rect at far left
                                        // (declared SECOND so it z-orders ABOVE the row toggle
                                        // — Slint orders by declaration; fix #3).
                                        Text {
                                            x: 4px;
                                            y: 0;
                                            width: 24px;
                                            height: parent.height;
                                            text: "☰";
                                            font-size: 14px;
                                            color: #aaaaaa;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                        drag-handle-area := TouchArea {
                                            x: 0;
                                            y: 0;
                                            width: 32px;
                                            height: parent.height;
                                            mouse-cursor: grab;
                                            pointer-event(event) => {
                                                if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                                                    root.dragging-tag-index = idx;
                                                    root.drag-start-y = self.absolute-position.y + self.mouse-y;
                                                    root.drag-current-y = root.drag-start-y;
                                                }
                                                if (event.kind == PointerEventKind.move && root.dragging-tag-index == idx) {
                                                    root.drag-current-y = self.absolute-position.y + self.mouse-y;
                                                }
                                                if (event.kind == PointerEventKind.up && root.dragging-tag-index == idx) {
                                                    root.drag-current-y = self.absolute-position.y + self.mouse-y;
                                                    root.export-tag-drag-released(idx, root.drag-current-y - root.selected-list-top-y);
                                                    root.dragging-tag-index = -1;
                                                }
                                                if (event.kind == PointerEventKind.cancel && root.dragging-tag-index == idx) {
                                                    root.dragging-tag-index = -1;
                                                }
                                            }
                                        }
                                    }
                                }

                                // Bottom Repeater: UNSELECTED tag rows in
                                // alphabetical order. No drag handles.
                                unselected-list := Rectangle {
                                    width: parent.width;
                                    height: root.unselected-export-tag-rows.length * 32px;
                                    background: transparent;

                                    for row[idx] in root.unselected-export-tag-rows: Rectangle {
                                        x: 0;
                                        y: idx * 32px;
                                        width: parent.width;
                                        height: 32px;
                                        background: unsel-toggle-area.pressed
                                            ? #2c5d8a
                                            : (unsel-toggle-area.has-hover ? #232323 : transparent);

                                        // Empty checkbox indicator.
                                        Rectangle {
                                            x: 32px;
                                            y: (parent.height - self.height) / 2;
                                            width: 16px;
                                            height: 16px;
                                            border-radius: 3px;
                                            border-width: 1px;
                                            border-color: #707070;
                                            background: transparent;
                                        }

                                        // Label.
                                        Text {
                                            x: 56px;
                                            y: 0;
                                            width: parent.width - 224px;
                                            height: parent.height;
                                            text: row.label;
                                            font-size: 13px;
                                            color: #ffffff;
                                            vertical-alignment: center;
                                            overflow: elide;
                                        }

                                        // Right-aligned count + duration.
                                        Text {
                                            x: parent.width - 168px;
                                            y: 0;
                                            width: 160px;
                                            height: parent.height;
                                            text: row.clip-count + " clip" + (row.clip-count == 1 ? "" : "s") + " · " + format-mmss(row.duration);
                                            font-size: 11px;
                                            color: #aaaaaa;
                                            vertical-alignment: center;
                                            horizontal-alignment: right;
                                        }

                                        unsel-toggle-area := TouchArea {
                                            width: parent.width;
                                            height: parent.height;
                                            clicked => { root.export-tag-toggled(row.tag); }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // Output folder picker row.
                    Text {
                        x: 24px;
                        y: 240px;
                        width: 120px;
                        height: 18px;
                        text: "Output folder";
                        font-size: 13px;
                        color: #aaaaaa;
                    }
                    Rectangle {
                        x: 24px;
                        y: 262px;
                        width: parent.width - 48px - 100px;
                        height: 28px;
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: #303030;
                        background: #161616;
                        Text {
                            x: 8px;
                            y: 0;
                            width: parent.width - 16px;
                            height: parent.height;
                            text: root.export-output-folder == ""
                                ? "(none — choose a folder)"
                                : root.export-output-folder;
                            font-size: 12px;
                            color: root.export-output-folder == "" ? #777777 : #dddddd;
                            font-family: "Menlo";
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }
                    of-button := Rectangle {
                        x: parent.width - 120px;
                        y: 262px;
                        width: 96px;
                        height: 28px;
                        border-radius: 4px;
                        background: of-area.pressed
                            ? #404040
                            : (of-area.has-hover ? #2e2e2e : #262626);
                        Text {
                            x: 0; y: 0;
                            width: parent.width; height: parent.height;
                            text: "Choose…";
                            font-size: 12px;
                            color: #ffffff;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        of-area := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => { root.export-folder-pick-clicked(); }
                        }
                    }

                    // Resolution picker row.
                    Text {
                        x: 24px;
                        y: 304px;
                        width: 120px;
                        height: 18px;
                        text: "Resolution";
                        font-size: 13px;
                        color: #aaaaaa;
                    }
                    res-source-btn := Rectangle {
                        x: 24px;
                        y: 326px;
                        width: 88px;
                        height: 28px;
                        border-radius: 4px;
                        background: root.export-resolution == "source"
                            ? #4a90e2
                            : (rs-area.has-hover ? #2e2e2e : #262626);
                        Text {
                            x: 0; y: 0;
                            width: parent.width; height: parent.height;
                            text: "Source";
                            font-size: 12px;
                            color: #ffffff;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        rs-area := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => { root.export-resolution-changed("source"); }
                        }
                    }
                    res-1080-btn := Rectangle {
                        x: 116px;
                        y: 326px;
                        width: 88px;
                        height: 28px;
                        border-radius: 4px;
                        background: root.export-resolution == "1080"
                            ? #4a90e2
                            : (r1080-area.has-hover ? #2e2e2e : #262626);
                        Text {
                            x: 0; y: 0;
                            width: parent.width; height: parent.height;
                            text: "1080p";
                            font-size: 12px;
                            color: #ffffff;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        r1080-area := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => { root.export-resolution-changed("1080"); }
                        }
                    }
                    res-720-btn := Rectangle {
                        x: 208px;
                        y: 326px;
                        width: 88px;
                        height: 28px;
                        border-radius: 4px;
                        background: root.export-resolution == "720"
                            ? #4a90e2
                            : (r720-area.has-hover ? #2e2e2e : #262626);
                        Text {
                            x: 0; y: 0;
                            width: parent.width; height: parent.height;
                            text: "720p";
                            font-size: 12px;
                            color: #ffffff;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        r720-area := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => { root.export-resolution-changed("720"); }
                        }
                    }

                    // Quality picker row.
                    Text {
                        x: 24px;
                        y: 366px;
                        width: 120px;
                        height: 18px;
                        text: "Quality";
                        font-size: 13px;
                        color: #aaaaaa;
                    }
                    q-low-btn := Rectangle {
                        x: 24px;
                        y: 388px;
                        width: 88px;
                        height: 28px;
                        border-radius: 4px;
                        background: root.export-quality == "low"
                            ? #4a90e2
                            : (ql-area.has-hover ? #2e2e2e : #262626);
                        Text {
                            x: 0; y: 0;
                            width: parent.width; height: parent.height;
                            text: "Low";
                            font-size: 12px;
                            color: #ffffff;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        ql-area := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => { root.export-quality-changed("low"); }
                        }
                    }
                    q-med-btn := Rectangle {
                        x: 116px;
                        y: 388px;
                        width: 88px;
                        height: 28px;
                        border-radius: 4px;
                        background: root.export-quality == "medium"
                            ? #4a90e2
                            : (qm-area.has-hover ? #2e2e2e : #262626);
                        Text {
                            x: 0; y: 0;
                            width: parent.width; height: parent.height;
                            text: "Medium";
                            font-size: 12px;
                            color: #ffffff;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        qm-area := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => { root.export-quality-changed("medium"); }
                        }
                    }
                    q-high-btn := Rectangle {
                        x: 208px;
                        y: 388px;
                        width: 88px;
                        height: 28px;
                        border-radius: 4px;
                        background: root.export-quality == "high"
                            ? #4a90e2
                            : (qh-area.has-hover ? #2e2e2e : #262626);
                        Text {
                            x: 0; y: 0;
                            width: parent.width; height: parent.height;
                            text: "High";
                            font-size: 12px;
                            color: #ffffff;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        qh-area := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => { root.export-quality-changed("high"); }
                        }
                    }

                    // Phase 11 Plan #3 Task 2: Codec picker row. Two
                    // buttons (H.264 / HEVC) below Quality; mirrors the
                    // Quality row's Rectangle/TouchArea shape exactly.
                    Text {
                        x: 24px;
                        y: 430px;
                        width: 120px;
                        height: 18px;
                        text: "Codec";
                        font-size: 13px;
                        color: #aaaaaa;
                    }
                    c-h264-btn := Rectangle {
                        x: 24px;
                        y: 452px;
                        width: 88px;
                        height: 28px;
                        border-radius: 4px;
                        background: root.export-codec == "h264"
                            ? #4a90e2
                            : (ch264-area.has-hover ? #2e2e2e : #262626);
                        Text {
                            x: 0; y: 0;
                            width: parent.width; height: parent.height;
                            text: "H.264";
                            font-size: 12px;
                            color: #ffffff;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        ch264-area := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => { root.export-codec-changed("h264"); }
                        }
                    }
                    c-hevc-btn := Rectangle {
                        x: 116px;
                        y: 452px;
                        width: 88px;
                        height: 28px;
                        border-radius: 4px;
                        background: root.export-codec == "hevc"
                            ? #4a90e2
                            : (chevc-area.has-hover ? #2e2e2e : #262626);
                        Text {
                            x: 0; y: 0;
                            width: parent.width; height: parent.height;
                            text: "HEVC";
                            font-size: 12px;
                            color: #ffffff;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        chevc-area := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => { root.export-codec-changed("hevc"); }
                        }
                    }

                    // Phase 11 Plan #7 Task 1: Filename template input row.
                    // Sits below the Codec row (Codec ends at y:480).
                    Text {
                        x: 24px;
                        y: 494px;
                        width: 120px;
                        height: 18px;
                        text: "Filename";
                        font-size: 13px;
                        color: #aaaaaa;
                    }
                    LineEdit {
                        x: 24px;
                        y: 516px;
                        width: 280px;
                        height: 28px;
                        text <=> root.export-filename-template;
                        edited(text) => { root.export-filename-template-changed(text); }
                    }
                    Text {
                        x: 24px;
                        y: 550px;
                        width: parent.width - 48px;
                        height: 16px;
                        text: "Placeholders: {tag}, {project}, {date}";
                        font-size: 11px;
                        color: #999999;
                    }

                    // Cancel + Export bottom buttons.
                    cancel-btn := Rectangle {
                        x: parent.width - 232px;
                        y: parent.height - 52px;
                        width: 96px;
                        height: 32px;
                        border-radius: 4px;
                        background: cancel-area.pressed
                            ? #404040
                            : (cancel-area.has-hover ? #2e2e2e : #262626);
                        Text {
                            x: 0; y: 0;
                            width: parent.width; height: parent.height;
                            text: "Cancel";
                            font-size: 13px;
                            color: #ffffff;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        cancel-area := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => { root.export-close-clicked(); }
                        }
                    }
                    export-btn := Rectangle {
                        x: parent.width - 124px;
                        y: parent.height - 52px;
                        width: 100px;
                        height: 32px;
                        border-radius: 4px;
                        background: can-export()
                            ? (export-area.pressed
                                ? #2c5d8a
                                : (export-area.has-hover ? #5ba0f2 : #4a90e2))
                            : #2a3a4a;
                        Text {
                            x: 0; y: 0;
                            width: parent.width; height: parent.height;
                            text: "Export";
                            font-size: 13px;
                            color: can-export() ? #ffffff : #888888;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        export-area := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => {
                                if (can-export()) {
                                    root.export-start-clicked();
                                }
                            }
                        }
                    }
                }

                // ────────────────── In-progress view ─────────────
                if root.export-outcome-kind == "in_progress": Rectangle {
                    x: 0;
                    y: 56px;
                    width: parent.width;
                    height: parent.height - 56px;

                    // Headline + spinner-equivalent (static glyph;
                    // Slint 1.8 doesn't ship an indeterminate
                    // spinner primitive and animating one via
                    // animate-rotation isn't worth the mass-of-code
                    // for a v1 ship).
                    Text {
                        x: 24px;
                        y: 60px;
                        width: parent.width - 48px;
                        height: 28px;
                        text: "Exporting " + root.export-current-tag + "…";
                        font-size: 15px;
                        color: #ffffff;
                        horizontal-alignment: center;
                    }
                    Text {
                        x: 24px;
                        y: 96px;
                        width: parent.width - 48px;
                        height: 22px;
                        // Phase 11 Plan #2 (Fix #9: `.round()` method
                        // form, NOT free `round(...)`).
                        text: (root.export-completed-tags + 1) + " of "
                            + root.export-total-tags + " — "
                            + (root.export-batch-progress * 100).round() + "%";
                        font-size: 12px;
                        color: #aaaaaa;
                        horizontal-alignment: center;
                    }

                    // Phase 11 Plan #2: horizontal progress bar bound to
                    // `export-batch-progress`. 200ms ease-out tween
                    // smooths the ~1 Hz throttled writer cadence into
                    // visually continuous motion.
                    Rectangle {
                        x: 80px;
                        y: 130px;
                        width: parent.width - 160px;
                        height: 8px;
                        background: #303030;
                        border-radius: 4px;

                        Rectangle {
                            x: 0;
                            y: 0;
                            width: parent.width * root.export-batch-progress;
                            height: parent.height;
                            background: #4a90e2;
                            border-radius: 4px;
                            animate width { duration: 200ms; easing: ease-out; }
                        }
                    }

                    // Cancel button.
                    cx-btn := Rectangle {
                        x: (parent.width - self.width) / 2;
                        y: parent.height - 60px;
                        width: 100px;
                        height: 32px;
                        border-radius: 4px;
                        background: cx-area.pressed
                            ? #404040
                            : (cx-area.has-hover ? #2e2e2e : #262626);
                        Text {
                            x: 0; y: 0;
                            width: parent.width; height: parent.height;
                            text: "Cancel";
                            font-size: 13px;
                            color: #ffffff;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        cx-area := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => { root.export-cancel-clicked(); }
                        }
                    }
                }

                // ────────────────── Success view ─────────────────
                if root.export-outcome-kind == "succeeded_all": Rectangle {
                    x: 0;
                    y: 56px;
                    width: parent.width;
                    height: parent.height - 56px;

                    Text {
                        x: 24px;
                        y: 60px;
                        width: parent.width - 48px;
                        height: 24px;
                        text: "Wrote " + root.export-summary-file-count + " file" + (root.export-summary-file-count == 1 ? "" : "s") + ".";
                        font-size: 14px;
                        color: #ffffff;
                        horizontal-alignment: center;
                    }
                    Text {
                        x: 24px;
                        y: 92px;
                        width: parent.width - 48px;
                        height: 20px;
                        text: root.export-summary-folder;
                        font-size: 11px;
                        color: #aaaaaa;
                        font-family: "Menlo";
                        horizontal-alignment: center;
                        overflow: elide;
                    }

                    // Reveal in Finder + Done buttons.
                    s-reveal-btn := Rectangle {
                        x: parent.width - 232px;
                        y: parent.height - 60px;
                        width: 140px;
                        height: 32px;
                        border-radius: 4px;
                        background: sr-area.pressed
                            ? #404040
                            : (sr-area.has-hover ? #2e2e2e : #262626);
                        Text {
                            x: 0; y: 0;
                            width: parent.width; height: parent.height;
                            text: "Reveal in Finder";
                            font-size: 12px;
                            color: #ffffff;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        sr-area := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => { root.export-reveal-clicked(); }
                        }
                    }
                    s-done-btn := Rectangle {
                        x: parent.width - 84px;
                        y: parent.height - 60px;
                        width: 60px;
                        height: 32px;
                        border-radius: 4px;
                        background: sd-area.pressed
                            ? #2c5d8a
                            : (sd-area.has-hover ? #5ba0f2 : #4a90e2);
                        Text {
                            x: 0; y: 0;
                            width: parent.width; height: parent.height;
                            text: "Done";
                            font-size: 13px;
                            color: #ffffff;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        sd-area := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => { root.export-close-clicked(); }
                        }
                    }
                }

                // ────────────── Partial-failure view ─────────────
                if root.export-outcome-kind == "partial_failure": pf-view := Rectangle {
                    x: 0;
                    y: 56px;
                    width: parent.width;
                    height: parent.height - 56px;

                    Text {
                        x: 24px;
                        y: 60px;
                        width: parent.width - 48px;
                        height: 24px;
                        text: "Export of '" + root.export-failed-tag + "' failed.";
                        font-size: 14px;
                        color: #ff6464;
                        horizontal-alignment: center;
                    }
                    Text {
                        x: 24px;
                        y: 92px;
                        width: parent.width - 48px;
                        height: 60px;
                        text: root.export-error;
                        font-size: 11px;
                        color: #cccccc;
                        font-family: "Menlo";
                        horizontal-alignment: center;
                        wrap: word-wrap;
                        overflow: elide;
                    }
                    Text {
                        x: 24px;
                        y: 158px;
                        width: parent.width - 48px;
                        height: 20px;
                        text: "Wrote " + root.export-completed-tags + " file" + (root.export-completed-tags == 1 ? "" : "s") + " before failure.";
                        font-size: 12px;
                        color: #aaaaaa;
                        horizontal-alignment: center;
                    }

                    // Reveal in Finder visible only when something
                    // landed on disk (per fix #36). Otherwise the
                    // Done button takes its slot.
                    if root.export-completed-tags > 0: Rectangle {
                        x: pf-view.width - 232px;
                        y: pf-view.height - 60px;
                        width: 140px;
                        height: 32px;
                        border-radius: 4px;
                        background: pf-rev-area.pressed
                            ? #404040
                            : (pf-rev-area.has-hover ? #2e2e2e : #262626);
                        Text {
                            x: 0; y: 0;
                            width: parent.width; height: parent.height;
                            text: "Reveal in Finder";
                            font-size: 12px;
                            color: #ffffff;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        pf-rev-area := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => { root.export-reveal-clicked(); }
                        }
                    }

                    pf-done-btn := Rectangle {
                        x: parent.width - 84px;
                        y: parent.height - 60px;
                        width: 60px;
                        height: 32px;
                        border-radius: 4px;
                        background: pf-done-area.pressed
                            ? #2c5d8a
                            : (pf-done-area.has-hover ? #5ba0f2 : #4a90e2);
                        Text {
                            x: 0; y: 0;
                            width: parent.width; height: parent.height;
                            text: "Done";
                            font-size: 13px;
                            color: #ffffff;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        pf-done-area := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => { root.export-close-clicked(); }
                        }
                    }
                }

                // ────────────────── Cancelled view ───────────────
                if root.export-outcome-kind == "cancelled": cn-view := Rectangle {
                    x: 0;
                    y: 56px;
                    width: parent.width;
                    height: parent.height - 56px;

                    Text {
                        x: 24px;
                        y: 60px;
                        width: parent.width - 48px;
                        height: 24px;
                        text: "Cancelled";
                        font-size: 14px;
                        color: #f4c430;
                        horizontal-alignment: center;
                    }
                    Text {
                        x: 24px;
                        y: 92px;
                        width: parent.width - 48px;
                        height: 20px;
                        text: "Wrote " + root.export-cancelled-completed + " file" + (root.export-cancelled-completed == 1 ? "" : "s") + " before cancel.";
                        font-size: 12px;
                        color: #aaaaaa;
                        horizontal-alignment: center;
                    }

                    // Reveal visible only when something landed.
                    if root.export-cancelled-completed > 0: Rectangle {
                        x: cn-view.width - 232px;
                        y: cn-view.height - 60px;
                        width: 140px;
                        height: 32px;
                        border-radius: 4px;
                        background: cn-rev-area.pressed
                            ? #404040
                            : (cn-rev-area.has-hover ? #2e2e2e : #262626);
                        Text {
                            x: 0; y: 0;
                            width: parent.width; height: parent.height;
                            text: "Reveal in Finder";
                            font-size: 12px;
                            color: #ffffff;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        cn-rev-area := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => { root.export-reveal-clicked(); }
                        }
                    }

                    cn-done-btn := Rectangle {
                        x: parent.width - 84px;
                        y: parent.height - 60px;
                        width: 60px;
                        height: 32px;
                        border-radius: 4px;
                        background: cn-done-area.pressed
                            ? #2c5d8a
                            : (cn-done-area.has-hover ? #5ba0f2 : #4a90e2);
                        Text {
                            x: 0; y: 0;
                            width: parent.width; height: parent.height;
                            text: "Done";
                            font-size: 13px;
                            color: #ffffff;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        cn-done-area := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => { root.export-close-clicked(); }
                        }
                    }
                }
            }
        }
    }

    // Phase 10 Task 3 helper used by the export sheet's Export
    // button. Slint's pure functions don't support `for` loops over
    // lists, so the `selected` membership query lives on the row
    // model itself (Rust-side hydrated, see comment on
    // export-tag-rows above).
    //
    // Phase 11 Plan #7 Task 1 (fix #5): also gated on
    // `dragging-tag-index == -1` so a click-Export-during-drag race
    // can't dispatch with the pre-drag selection order.
    pure function can-export() -> bool {
        return root.selected-export-tags.length > 0
            && root.export-output-folder != ""
            && root.dragging-tag-index == -1;
    }

    // mm:ss formatter as a pure function. Slint 1.16 supports
    // `function` items for this.
    function format-mmss(t: float) -> string {
        if (t < 0) {
            return "0:00";
        }
        return floor(t / 60) + ":" + (mod(floor(t), 60) < 10 ? "0" : "") + mod(floor(t), 60);
    }
}
